# BATANA USSD Gateway — Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=4000
NODE_ENV=development

# Backend API (your existing BATANA backend)
BACKEND_URL=http://localhost:5000

# Africa's Talking
AT_USERNAME=sandbox
AT_API_KEY=your_at_api_key_here

# Upstash Redis (session storage)
# Get from: https://console.upstash.com
REDIS_URL=redis://default:your_password@your-endpoint.upstash.io:6379

# Session config
SESSION_TTL_SECONDS=300